pkg/crypto/crypto.go

```go
package crypto

import (
    "crypto/ed25519"
    "crypto/rand"
    "os"
    "path/filepath"

    "github.com/libp2p/go-libp2p/core/crypto"
)

type Crypto struct {
    privKey crypto.PrivKey
    pubKey  crypto.PubKey
}

func New(keyDir string) (*Crypto, error) {
    keyPath := filepath.Join(keyDir, "node.key")
    privBytes, err := os.ReadFile(keyPath)
    if err == nil {
        privKey, err := crypto.UnmarshalEd25519PrivateKey(privBytes)
        if err != nil {
            return nil, err
        }
        return &Crypto{privKey: privKey, pubKey: privKey.GetPublic()}, nil
    }

    privKey, _, err := crypto.GenerateEd25519Key(rand.Reader)
    if err != nil {
        return nil, err
    }
    privBytes, err = crypto.MarshalPrivateKey(privKey)
    if err != nil {
        return nil, err
    }
    if err := os.MkdirAll(keyDir, 0700); err != nil {
        return nil, err
    }
    if err := os.WriteFile(keyPath, privBytes, 0600); err != nil {
        return nil, err
    }
    return &Crypto{privKey: privKey, pubKey: privKey.GetPublic()}, nil
}

func (c *Crypto) GetLibp2pPrivKey() (crypto.PrivKey, error) {
    return c.privKey, nil
}

func (c *Crypto) Sign(data []byte) ([]byte, error) {
    return c.privKey.Sign(data)
}

func (c *Crypto) Verify(pubKeyBytes []byte, data, sig []byte) (bool, error) {
    pubKey, err := crypto.UnmarshalEd25519PublicKey(pubKeyBytes)
    if err != nil {
        return false, err
    }
    return pubKey.Verify(data, sig)
}

func GenerateEd25519Key() (crypto.PrivKey, error) {
    return crypto.GenerateEd25519Key(rand.Reader)
}
