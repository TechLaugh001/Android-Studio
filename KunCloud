    switch cmd {
    case "genkey":
        key, err := crypto.GenerateEd25519Key()
        if err != nil {
            fmt.Fprintf(os.Stderr, "Failed to generate key: %v\n", err)
            os.Exit(1)
        }
        privBytes, err := key.Raw()
        if err != nil {
            fmt.Fprintf(os.Stderr, "Failed to encode key: %v\n", err)
            os.Exit(1)
        }
        fmt.Printf("Private key (hex): %x\n", privBytes)
    default:
        fmt.Println("Usage: cli -cmd genkey")
    }
}
