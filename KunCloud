package reed_solomon

import (
    "github.com/klauspost/reedsolomon"
)

type Encoder struct {
    enc reedsolomon.Encoder
}

func New(dataShards, parityShards int) *Encoder {
    enc, _ := reedsolomon.New(dataShards, parityShards)
    return &Encoder{enc: enc}
}

func (e *Encoder) Encode(data [][]byte) [][]byte {
    shards := make([][]byte, len(data)+e.enc.ParityShards())
    copy(shards, data)
    for i := len(data); i < len(shards); i++ {
        shards[i] = make([]byte, len(data[0]))
    }
    _ = e.enc.Encode(shards)
    return shards
}

func (e *Encoder) Decode(shards [][]byte) ([][]byte, error) {
    if err := e.enc.Reconstruct(shards); err != nil {
        return nil, err
    }
    dataShards := shards[:e.enc.DataShards()]
    return dataShards, nil
}
