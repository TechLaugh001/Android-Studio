package main

import (
    "context"
    "flag"
    "os"
    "os/signal"
    "syscall"
    "time"

    "github.com/kuncloud/kuncloud/pkg/api/grpc"
    "github.com/kuncloud/kuncloud/pkg/api/rest"
    "github.com/kuncloud/kuncloud/pkg/common"
    "github.com/kuncloud/kuncloud/pkg/crypto"
    "github.com/kuncloud/kuncloud/pkg/p2p"
    "github.com/kuncloud/kuncloud/pkg/storage"
    "github.com/kuncloud/kuncloud/pkg/scheduler"
    "github.com/kuncloud/kuncloud/pkg/ai"
    "github.com/kuncloud/kuncloud/pkg/vehicle"
    "github.com/kuncloud/kuncloud/pkg/sync"
    "github.com/kuncloud/kuncloud/pkg/sovereignty"
    "github.com/sirupsen/logrus"
)

func main() {
    var configPath string
    flag.StringVar(&configPath, "config", "configs/config.yaml", "path to config file")
    flag.Parse()

    logrus.SetFormatter(&logrus.TextFormatter{FullTimestamp: true})
    logrus.SetLevel(logrus.DebugLevel)

    cfg, err := common.LoadConfig(configPath)
    if err != nil {
        logrus.Fatalf("Failed to load config: %v", err)
    }

    cryptoMod, err := crypto.New(cfg.KeyDir)
    if err != nil {
        logrus.Fatalf("Failed to init crypto: %v", err)
    }

    host, err := p2p.NewHost(cfg.P2P, cryptoMod)
    if err != nil {
        logrus.Fatalf("Failed to create P2P host: %v", err)
    }
    defer host.Close()

    storageEngine, err := storage.NewEngine(cfg.Storage, host, cryptoMod)
    if err != nil {
        logrus.Fatalf("Failed to init storage: %v", err)
    }
    defer storageEngine.Close()

    schedulerEngine, err := scheduler.NewScheduler(cfg.Scheduler, host)
    if err != nil {
        logrus.Fatalf("Failed to init scheduler: %v", err)
    }

    aiEngine, err := ai.NewEngine(cfg.AI, storageEngine, cryptoMod)
    if err != nil {
        logrus.Fatalf("Failed to init AI: %v", err)
    }

    var vehicleModule *vehicle.Module
    if cfg.Vehicle.Enabled {
        vehicleModule, err = vehicle.NewModule(cfg.Vehicle, cryptoMod)
        if err != nil {
            logrus.Warnf("Failed to init vehicle module: %v", err)
        }
    }

    syncEngine, err := sync.NewSync(cfg.Sync, host, storageEngine)
    if err != nil {
        logrus.Fatalf("Failed to init sync: %v", err)
    }

    sovereigntyEngine, err := sovereignty.New(cfg.Sovereignty, storageEngine, cryptoMod)
    if err != nil {
        logrus.Fatalf("Failed to init sovereignty: %v", err)
    }

    grpcServer := grpc.NewServer(cfg.API.GRPC.Listen, storageEngine, schedulerEngine, aiEngine, vehicleModule, syncEngine, sovereigntyEngine)
    go func() {
        if err := grpcServer.Start(); err != nil {
            logrus.Fatalf("gRPC server failed: %v", err)
        }
    }()

    if cfg.API.REST.Enabled {
        restServer := rest.NewServer(cfg.API.REST.Listen, grpcServer)
        go func() {
            if err := restServer.Start(); err != nil {
                logrus.Fatalf("REST server failed: %v", err)
            }
        }()
    }

    logrus.Info("KunCloud node started successfully")

    quit := make(chan os.Signal, 1)
    signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)
    <-quit

    logrus.Info("Shutting down...")

    ctx, cancel := context.WithTimeout(context.Background(), cfg.ShutdownTimeout)
    defer cancel()

    if err := grpcServer.Stop(ctx); err != nil {
        logrus.Errorf("Error stopping gRPC server: %v", err)
    }
    if err := storageEngine.Close(); err != nil {
        logrus.Errorf("Error closing storage: %v", err)
    }
}
