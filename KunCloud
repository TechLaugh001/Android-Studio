pkg/storage/encryption/encryption.go

```go
package encryption

import (
    "crypto/aes"
    "crypto/cipher"
    "crypto/rand"
    "io"

    "github.com/kuncloud/kuncloud/pkg/crypto"
)

type Encryptor struct {
    crypto *crypto.Crypto
}

func New(crypto *crypto.Crypto) *Encryptor {
    return &Encryptor{crypto: crypto}
}

func (e *Encryptor) EncryptChunks(chunks [][]byte) ([][]byte, [][]byte, error) {
    encrypted := make([][]byte, len(chunks))
    keys := make([][]byte, len(chunks))
    for i, chunk := range chunks {
        key := make([]byte, 32)
        if _, err := io.ReadFull(rand.Reader, key); err != nil {
            return nil, nil, err
        }
        block, err := aes.NewCipher(key)
        if err != nil {
            return nil, nil, err
        }
        gcm, err := cipher.NewGCM(block)
        if err != nil {
            return nil, nil, err
        }
        nonce := make([]byte, gcm.NonceSize())
        if _, err := io.ReadFull(rand.Reader, nonce); err != nil {
            return nil, nil, err
        }
        encrypted[i] = gcm.Seal(nonce, nonce, chunk, nil)
        keys[i] = key
    }
    return encrypted, keys, nil
}

func (e *Encryptor) DecryptChunks(encryptedChunks [][]byte, keys [][]byte) ([][]byte, error) {
    chunks := make([][]byte, len(encryptedChunks))
    for i, data := range encryptedChunks {
        key := keys[i]
        block, err := aes.NewCipher(key)
        if err != nil {
            return nil, err
        }
        gcm, err := cipher.NewGCM(block)
        if err != nil {
            return nil, err
        }
        nonceSize := gcm.NonceSize()
        if len(data) < nonceSize {
            return nil, io.ErrUnexpectedEOF
        }
        nonce, ciphertext := data[:nonceSize], data[nonceSize:]
        chunk, err := gcm.Open(nil, nonce, ciphertext, nil)
        if err != nil {
            return nil, err
        }
        chunks[i] = chunk
    }
    return chunks, nil
}
