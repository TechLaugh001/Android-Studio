    ShutdownTimeout time.Duration
}

type P2PConfig struct {
    ListenAddrs    []string
    BootstrapPeers []string
    EnableMDNS     bool
    EnableDHT      bool
}

type StorageConfig struct {
    DataDir      string
    ChunkSize    int
    DataShards   int
    ParityShards int
}

type DatabaseConfig struct {
    Engine string // "kv" or "cockroach"
}

type SchedulerConfig struct {
    MaxConcurrent int
}

type AIConfig struct {
    ModelsDir string
    EnableGPU bool
}

type VehicleConfig struct {
    Enabled      bool
    CANInterface string
    CameraDevice string
}

type SyncConfig struct {
    AutoSync bool
}

type SovereigntyConfig struct {
    AuditEnabled bool
}

type APIConfig struct {
    GRPC GRPCConfig
    REST RESTConfig
}

type GRPCConfig struct {
    Listen string
}

type RESTConfig struct {
    Enabled bool
    Listen  string
}

func LoadConfig(path string) (*Config, error) {
    viper.SetConfigFile(path)
    viper.SetConfigType("yaml")
    viper.AutomaticEnv()

    if err := viper.ReadInConfig(); err != nil {
        return nil, err
    }

    var cfg Config
    if err := viper.Unmarshal(&cfg); err != nil {
        return nil, err
    }

    if cfg.ShutdownTimeout == 0 {
        cfg.ShutdownTimeout = 30 * time.Second
    }
    if cfg.Storage.ChunkSize == 0 {
        cfg.Storage.ChunkSize = 1024 * 1024
    }
    if cfg.Storage.DataShards == 0 {
        cfg.Storage.DataShards = 4
    }
    if cfg.Storage.ParityShards == 0 {
        cfg.Storage.ParityShards = 2
    }

    return &cfg, nil
}
