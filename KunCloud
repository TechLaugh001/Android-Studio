package p2p

import (
    "context"
    "fmt"

    "github.com/libp2p/go-libp2p"
    "github.com/libp2p/go-libp2p/core/crypto"
    "github.com/libp2p/go-libp2p/core/host"
    "github.com/libp2p/go-libp2p/core/peer"
    "github.com/libp2p/go-libp2p/p2p/discovery/mdns"
    dht "github.com/libp2p/go-libp2p-kad-dht"
    "github.com/multiformats/go-multiaddr"
)

type Host struct {
    ctx  context.Context
    host host.Host
    dht  *dht.IpfsDHT
}

type Config struct {
    ListenAddrs    []string
    BootstrapPeers []string
    EnableMDNS     bool
    EnableDHT      bool
}

func NewHost(cfg *Config, privKey crypto.PrivKey) (*Host, error) {
    ctx := context.Background()

    var addrs []multiaddr.Multiaddr
    for _, addr := range cfg.ListenAddrs {
        ma, err := multiaddr.NewMultiaddr(addr)
        if err != nil {
            return nil, fmt.Errorf("invalid listen address %s: %w", addr, err)
        }
        addrs = append(addrs, ma)
    }

    h, err := libp2p.New(
        libp2p.ListenAddrs(addrs...),
        libp2p.Identity(privKey),
        libp2p.DefaultTransports,
        libp2p.DefaultMuxers,
        libp2p.DefaultSecurity,
        libp2p.NATPortMap(),
        libp2p.EnableRelay(),
    )
    if err != nil {
        return nil, err
    }

    host := &Host{
        ctx:  ctx,
        host: h,
    }

    if cfg.EnableDHT {
        dht, err := dht.New(ctx, h, dht.Mode(dht.ModeServer))
        if err != nil {
            h.Close()
            return nil, err
        }
        host.dht = dht
        if err := dht.Bootstrap(ctx); err != nil {
            return nil, err
        }
        for _, addr := range cfg.BootstrapPeers {
            peerInfo, err := peer.AddrInfoFromString(addr)
            if err != nil {
                continue
            }
            if err := h.Connect(ctx, *peerInfo); err != nil {
                fmt.Printf("Failed to connect to bootstrap peer %s: %v\n", addr, err)
            }
        }
    }

    if cfg.EnableMDNS {
        ser := mdns.NewMdnsService(h, "kuncloud", &discoveryNotifee{host: host})
        if err := ser.Start(); err != nil {
            return nil, err
        }
    }

    return host, nil
}

type discoveryNotifee struct {
    host *Host
}

func (n *discoveryNotifee) HandlePeerFound(pi peer.AddrInfo) {
    fmt.Printf("Discovered new peer: %s\n", pi.ID)
}

func (h *Host) Close() error {
    if h.dht != nil {
        h.dht.Close()
    }
    return h.host.Close()
}

func (h *Host) GetHost() host.Host {
    return h.host
}

func (h *Host) GetDHT() *dht.IpfsDHT {
    return h.dht
}
