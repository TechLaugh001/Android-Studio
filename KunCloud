package chunker

import (
    "io"
)

type Chunker struct {
    size int
}

func New(size int) *Chunker {
    return &Chunker{size: size}
}

func (c *Chunker) Split(r io.Reader) ([][]byte, error) {
    var chunks [][]byte
    buf := make([]byte, c.size)
    for {
        n, err := r.Read(buf)
        if n > 0 {
            chunk := make([]byte, n)
            copy(chunk, buf[:n])
            chunks = append(chunks, chunk)
        }
        if err == io.EOF {
            break
        }
        if err != nil {
            return nil, err
        }
    }
    return chunks, nil
}

func (c *Chunker) Join(chunks [][]byte, w io.Writer) error {
    for _, chunk := range chunks {
        if _, err := w.Write(chunk); err != nil {
            return err
        }
    }
    return nil
}
