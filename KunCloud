package storage

import (
    "context"
    "io"
    "sync"

    "github.com/ipfs/go-cid"
    "github.com/kuncloud/kuncloud/pkg/p2p"
    "github.com/kuncloud/kuncloud/pkg/crypto"
    "github.com/kuncloud/kuncloud/pkg/storage/chunker"
    "github.com/kuncloud/kuncloud/pkg/storage/encryption"
    "github.com/kuncloud/kuncloud/pkg/storage/reed_solomon"
    "github.com/kuncloud/kuncloud/pkg/storage/dht"
    "github.com/kuncloud/kuncloud/pkg/storage/bitswap"
    "github.com/kuncloud/kuncloud/pkg/storage/local"
)

type Engine struct {
    chunker   *chunker.Chunker
    encryptor *encryption.Encryptor
    rs        *reed_solomon.Encoder
    dht       *dht.DHT
    bitswap   *bitswap.Bitswap
    local     *local.Store
    mu        sync.RWMutex
    closed    bool
}

type Config struct {
    DataDir      string
    ChunkSize    int
    DataShards   int
    ParityShards int
}

func NewEngine(cfg *Config, host *p2p.Host, crypto *crypto.Crypto) (*Engine, error) {
    chunker := chunker.New(cfg.ChunkSize)
    encryptor := encryption.New(crypto)
    rs := reed_solomon.New(cfg.DataShards, cfg.ParityShards)
    dht := dht.New(host)
    bitswap := bitswap.New(host, dht)
    local, err := local.New(cfg.DataDir)
    if err != nil {
        return nil, err
    }

    return &Engine{
        chunker:   chunker,
        encryptor: encryptor,
        rs:        rs,
        dht:       dht,
        bitswap:   bitswap,
        local:     local,
    }, nil
}

func (e *Engine) Put(ctx context.Context, reader io.Reader) (cid.Cid, error) {
    e.mu.RLock()
    if e.closed {
        e.mu.RUnlock()
        return cid.Undef, io.ErrClosedPipe
    }
    e.mu.RUnlock()

    chunks, err := e.chunker.Split(reader)
    if err != nil {
        return cid.Undef, err
    }

    encryptedChunks, keys, err := e.encryptor.EncryptChunks(chunks)
    if err != nil {
        return cid.Undef, err
    }

    shards := e.rs.Encode(encryptedChunks)

    var shardCIDs []cid.Cid
    for _, shard := range shards {
        c, err := e.local.Put(shard)
        if err != nil {
            return cid.Undef, err
        }
        shardCIDs = append(shardCIDs, c)
    }

    rootNode, err := e.buildDAG(shardCIDs, keys)
    if err != nil {
        return cid.Undef, err
    }
    rootCID := rootNode.Cid()

    if err := e.dht.Provide(ctx, rootCID, shardCIDs); err != nil {
        return cid.Undef, err
    }

    go e.bitswap.Distribute(ctx, shardCIDs, shards)

    return rootCID, nil
}

func (e *Engine) Get(ctx context.Context, root cid.Cid, writer io.Writer) error {
    e.mu.RLock()
    if e.closed {
        e.mu.RUnlock()
        return io.ErrClosedPipe
    }
    e.mu.RUnlock()

    shardCIDs, keys, err := e.dht.FindShards(ctx, root)
    if err != nil {
        return err
    }

    var shards [][]byte
    for _, scid := range shardCIDs {
        data, err := e.bitswap.Get(ctx, scid)
        if err != nil {
            return err
        }
        shards = append(shards, data)
    }

    encryptedChunks, err := e.rs.Decode(shards)
    if err != nil {
        return err
    }

    chunks, err := e.encryptor.DecryptChunks(encryptedChunks, keys)
    if err != nil {
        return err
    }

    return e.chunker.Join(chunks, writer)
}

func (e *Engine) Close() error {
    e.mu.Lock()
    defer e.mu.Unlock()
    if e.closed {
        return nil
    }
